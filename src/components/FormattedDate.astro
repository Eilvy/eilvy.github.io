---
interface Props {
	date: Date;
	locale?: string;
	options?: Intl.DateTimeFormatOptions;
}

const {
	date,
	locale = 'zh-CN',
	options = {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	},
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString(locale, options);
---

<time datetime={new Date(date).toISOString()}>{formattedDate}</time>
