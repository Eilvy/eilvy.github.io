---
import { SITE_TITLE } from '../consts'
import { SITE_DESCRIPTION } from '../consts'
interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: 'website' | 'article';
	publishedDate?: string;
	author?: string;
	tags?: string[];
}

const {
	title,
	description = { SITE_DESCRIPTION },
	image,
	canonicalURL,
	type = 'website',
	publishedDate,
	author = { SITE_TITLE },
	tags = []
} = Astro.props;

const siteURL = Astro.site ? new URL(Astro.site) : new URL('https://eilvy.github.io');
const ogImage = image ? new URL(image, siteURL) : new URL('/og-image.png', siteURL);
const canonical = canonicalURL || Astro.url.href;

// JSON-LD 结构化数据
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': type === 'article' ? 'BlogPosting' : 'Blog',
	...(type === 'article' && {
		headline: title,
		description: description,
		image: ogImage.href,
		datePublished: publishedDate,
		author: {
			'@type': 'Person',
			name: author
		}
	}),
	...(type === 'website' && {
		name: 'eilvy 的技术博客',
		url: siteURL.href,
		description: description,
		author: {
			'@type': 'Person',
			name: author
		}
	})
};
---

<!-- 基础 Meta 标签 -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<link rel="canonical" href={canonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage.href} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="eilvy 的技术博客" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage.href} />

<!-- 文章特定 Meta -->
{type === 'article' && (
	<>
		<meta property="article:published_time" content={publishedDate} />
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<meta property="article:author" content={author} />
	</>
)}

<!-- JSON-LD 结构化数据 -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
