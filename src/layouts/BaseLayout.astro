---
interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { title, description = 'eilvy 的技术博客 - 分享前端开发、TypeScript、Astro 等技术文章', image, canonicalURL } = Astro.props;

const siteURL = Astro.site ? new URL(Astro.site) : new URL('https://eilvy.github.io');
const ogImage = image ? new URL(image, siteURL) : new URL('/og-image.png', siteURL);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={ogImage.href} />
		<meta property="og:url" content={Astro.url.href} />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage.href} />
		
		<!-- Preconnect to fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<!-- Global styles -->
		<link rel="stylesheet" href="/styles/global.css" />
	</head>
	<body>
		<a href="#main-content" class="skip-link">跳转到主要内容</a>
		<slot />
	</body>
</html>

<style is:global>
	/* Skip link for accessibility */
	.skip-link {
		position: absolute;
		top: -40px;
		left: 0;
		background: var(--color-primary);
		color: white;
		padding: 8px 16px;
		z-index: 100;
		transition: top 0.3s;
	}
	
	.skip-link:focus {
		top: 0;
	}
</style>
