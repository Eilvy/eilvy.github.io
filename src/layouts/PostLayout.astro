---
import BlogLayout from './BlogLayout.astro';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import FormattedDate from '../components/FormattedDate.astro';
import Tag from '../components/Tag.astro';

interface BlogPostData {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags: string[];
	categories: string[];
	heroImage?: string | ImageMetadata;
	author?: string;
	draft?: boolean;
}

const { title, description, pubDate, updatedDate, tags, categories, heroImage, author } = Astro.props as BlogPostData;

// heroImage 可能已经是 ImageMetadata 对象（由 Astro 内容集合自动处理）
// 或者是字符串路径（需要手动处理）
const getHeroImage = async (path?: string | ImageMetadata): Promise<ImageMetadata | undefined> => {
	if (!path) return undefined;
	
	// 如果已经是 ImageMetadata 对象，直接返回
	if (typeof path === 'object' && 'src' in path) {
		return path as ImageMetadata;
	}
	
	// 如果是字符串，说明 Astro 没有自动处理，需要手动导入
	if (typeof path === 'string') {
		try {
			// 处理相对路径：从 src/content/blog/ 转换为相对于 PostLayout 的路径
			let importPath: string;
			
			if (path.startsWith('../../assets/')) {
				// 从 content/blog/ 到 assets/ 的相对路径
				importPath = path;
			} else if (path.startsWith('../assets/')) {
				// 调整路径
				importPath = `.${path}`;
			} else if (path.startsWith('/assets/')) {
				// 绝对路径转换为相对路径
				importPath = `../${path.substring(1)}`;
			} else if (path.includes('assets/')) {
				const match = path.match(/assets\/(.*)$/);
				if (match) {
					importPath = `../assets/${match[1]}`;
				} else {
					return undefined;
				}
			} else {
				return undefined;
			}
			
			const imageModule = await import(importPath);
			return imageModule.default as ImageMetadata;
		} catch (error) {
			console.warn(`Failed to load image: ${path}`, error);
			return undefined;
		}
	}
	
	return undefined;
};

const heroImageMetadata = await getHeroImage(heroImage);
---

<BlogLayout 
	title={title} 
	description={description}
	image={heroImageMetadata}
	type="article"
	publishedDate={pubDate?.toISOString()}
	author={author}
	tags={tags}
>
	<div class="post-layout">
		<main class="article-main">
			<article class="prose">
				<header class="post-header">
					{heroImageMetadata && (
						<div class="hero-image">
							<img src={heroImageMetadata.src} alt={title} />
						</div>
					)}
					
					<h1>{title}</h1>
					
					<div class="post-meta">
						<div class="meta-left">
							<FormattedDate date={pubDate} compact />
							{updatedDate && (
								<span class="updated-date">
									· 更新于 <FormattedDate date={updatedDate} compact />
								</span>
							)}
							{author && <span class="author">· {author}</span>}
						</div>
						
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => (
									<Tag name={tag} />
								))}
							</div>
						)}
					</div>
				</header>
				
				<div class="post-content">
					<slot />
				</div>
				
				<footer class="post-footer">
					{categories && categories.length > 0 && (
						<div class="categories">
							<span class="label">分类：</span>
							{categories.map((category: string) => (
								<Tag name={category} />
							))}
						</div>
					)}
				</footer>
			</article>
		</main>
		
		<aside class="toc-sidebar">
			<slot name="toc" />
		</aside>
	</div>
</BlogLayout>

<style>
	.post-layout {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 3em;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	
	.toc-sidebar {
		position: sticky;
		top: 100px;
		height: fit-content;
	}
	
	.article-main {
		min-width: 0;
	}
	
	@media (max-width: 1024px) {
		.post-layout {
			grid-template-columns: 1fr;
			max-width: 720px;
		}
		
		.toc-sidebar {
			display: none;
		}
	}
</style>

<style>
	.post-header {
		margin-bottom: 2rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--color-border);
	}
	
	h1 {
		font-size: 2.5rem;
		line-height: 1.2;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.post-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
		color: var(--color-text-light);
		font-size: 0.875rem;
	}
	
	.meta-left {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	
	.tags, .categories {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	
	.categories .label {
		font-weight: 500;
	}
	
	.hero-image {
		margin-bottom: 2rem;
	}
	
	.hero-image img {
		width: 100%;
		max-height: 400px;
		object-fit: cover;
		border-radius: 12px;
	}
	
	.post-content {
		margin: 2rem 0;
	}
	
	.post-footer {
		margin-top: 3rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
	}
	
	@media (max-width: 768px) {
		h1 {
			font-size: 1.875rem;
		}
		
		.post-meta {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
