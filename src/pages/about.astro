---
import BlogLayout from '../layouts/BlogLayout.astro';
import { SITE_TITLE } from '../consts';
---

<BlogLayout title={`关于我 - ${SITE_TITLE}`} description="关于 eilvy 的个人介绍">
	<div class="about-page">
		<header class="about-header">
			<h1>👋 你好！这里是Eilvy！</h1>
			<p class="subtitle">eilvy(Eiluy_468) · 运维开发 / 全栈(主后端)开发者</p>
			<p class="tagline">后端开发者 / 技术爱好者 / 终身学习者</p>
		</header>
		
		<div class="about-content">
			<section class="intro">
				<h2>👋 你好！</h2>
				<p>
					我是<strong>Eilvy</strong>，一名热爱技术的运维开发者和全栈(主后端)开发者。
				</p>
				<p>
					我热衷于探索新技术，分享知识，并致力于创造优秀的用户体验和高效的运维解决方案。
					这个博客是我记录学习历程、分享技术文章的平台。在这里，你会找到关于后端开发、
					VibeCoding、运维开发等主题的文章。
				</p>
				<div class="contact-info">
					<a href="mailto:stellaeil@outlook.com" class="contact-item">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
							<polyline points="22,6 12,13 2,6"/>
						</svg>
						stellaeil@outlook.com
					</a>
					<a href="https://github.com/eilvy" target="_blank" rel="noopener noreferrer" class="contact-item">
						<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
						github.com/eilvy
					</a>
					<span class="contact-item">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
							<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
						</svg>
						18883975776
					</span>
				</div>
			</section>
			
			<section class="skills">
				<h2>🛠️ 技术栈</h2>
				<div class="skill-categories">
					<div class="skill-category">
						<h3>运维开发</h3>
						<ul class="skill-list">
							<li>Linux 服务器管理</li>
							<li>Docker & Kubernetes</li>
							<li>Informer</li>
							<li>CI/CD Pipeline</li>
							<li>GitLab CI</li>
							<li>Gitea</li>
						</ul>
					</div>
					
					<div class="skill-category">
						<h3>后端开发</h3>
						<ul class="skill-list">
							<li>Go</li>
							<li>Python (Django/Flask)</li>
							<li>MySQL</li>
							<li>Redis</li>
							<li>Nginx</li>
						</ul>
					</div>
					
					<div class="skill-category">
						<h3>工具 & 平台</h3>
						<ul class="skill-list">
							<li>Git & GitHub</li>
							<li>VS Code</li>
							<li>Trae</li>
							<li>Cursor</li>
							<li>npm / pnpm</li>
							<li>Vite</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="interests">
				<h2>💡 感兴趣的话题</h2>
				<div class="interests-list">
					<span class="interest-tag">运维开发</span>
					<span class="interest-tag">Kubernetes</span>
					<span class="interest-tag">Docker</span>
					<span class="interest-tag">后端性能优化</span>
					<span class="interest-tag">TypeScript</span>
					<span class="interest-tag">Golang</span>
					<span class="interest-tag">Python</span>
					<span class="interest-tag">Linux 系统</span>
					<span class="interest-tag">开源项目</span>
					<span class="interest-tag">技术分享</span>
					<span class="interest-tag">VibeCoding</span>
				</div>
			</section>
			
			<section class="contact">
				<h2>📬 教育背景</h2>
				<div class="education-info">
					<p>软件工程</p>
					<p class="education-desc">主修课程：数据结构、操作系统、计算机网络、数据库系统、集群运维等</p>
				</div>
			</section>
		</div>
	</div>
	
	<style>
		.about-page {
			width: 100%;
			max-width: 800px;
			margin: 0 auto;
			padding: 3em 1em;
		}
		
		.about-header {
			text-align: center;
			margin-bottom: 3em;
			padding: 2em;
			background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
			border-radius: 16px;
			border: 1px solid var(--color-border);
		}
		
		.about-header h1 {
			font-size: 2.5rem;
			margin: 0 0 0.5em 0;
			background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}
		
		.about-header .subtitle {
			font-size: 1.125rem;
			color: var(--color-text-light);
			margin: 0.5em 0 0 0;
		}
		
		.about-header .tagline {
			font-size: 0.875rem;
			color: var(--color-text-light);
			margin: 0.5em 0 0 0;
		}
		
		.contact-info {
			display: flex;
			flex-wrap: wrap;
			gap: 1em;
			margin-top: 1.5em;
			padding-top: 1.5em;
			border-top: 1px solid var(--color-border);
		}
		
		.contact-item {
			display: flex;
			align-items: center;
			gap: 0.5em;
			padding: 0.5em 1em;
			background-color: var(--color-bg-secondary);
			color: var(--color-text);
			text-decoration: none;
			border-radius: 8px;
			border: 1px solid var(--color-border);
			font-size: 0.875rem;
			transition: all 0.2s;
		}
		
		.contact-item:hover {
			border-color: var(--color-primary);
			color: var(--color-primary);
		}
		
		.contact-item svg {
			width: 18px;
			height: 18px;
			flex-shrink: 0;
		}
		
		.about-content {
			display: flex;
			flex-direction: column;
			gap: 3em;
		}
		
		section h2 {
			font-size: 1.75rem;
			margin-bottom: 1em;
			color: var(--color-text);
		}
		
		.intro p {
			line-height: 1.8;
			color: var(--color-text);
			margin-bottom: 1em;
		}
		
		.skill-categories {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			gap: 1.5em;
		}
		
		.skill-category {
			background-color: var(--color-bg-secondary);
			padding: 1.5em;
			border-radius: 12px;
			border: 1px solid var(--color-border);
		}
		
		.skill-category h3 {
			font-size: 1.125rem;
			margin: 0 0 1em 0;
			color: var(--color-primary);
		}
		
		.skill-list {
			list-style: none;
			padding: 0;
			margin: 0;
		}
		
		.skill-list li {
			padding: 0.5em 0;
			color: var(--color-text);
			border-bottom: 1px solid var(--color-border);
		}
		
		.skill-list li:last-child {
			border-bottom: none;
		}
		
		.interests-list {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75em;
		}
		
		.interest-tag {
			display: inline-block;
			padding: 0.5em 1em;
			background-color: var(--color-bg-secondary);
			color: var(--color-text);
			border-radius: 9999px;
			font-size: 0.875rem;
			border: 1px solid var(--color-border);
		}
		
		.experience-list {
			display: flex;
			flex-direction: column;
			gap: 2em;
		}
		
		.experience-item {
			background-color: var(--color-bg-secondary);
			padding: 1.5em;
			border-radius: 12px;
			border: 1px solid var(--color-border);
		}
		
		.experience-item h3 {
			font-size: 1.25rem;
			margin: 0 0 0.5em 0;
			color: var(--color-text);
		}
		
		.experience-period {
			font-size: 0.875rem;
			color: var(--color-text-light);
			margin: 0 0 0.25em 0;
		}
		
		.experience-role {
			font-size: 0.875rem;
			color: var(--color-primary);
			margin: 0 0 1em 0;
			font-weight: 500;
		}
		
		.experience-item ul {
			margin: 0;
			padding-left: 1.5em;
		}
		
		.experience-item li {
			margin-bottom: 0.5em;
			color: var(--color-text);
			line-height: 1.6;
		}
		
		.education-info {
			background-color: var(--color-bg-secondary);
			padding: 1.5em;
			border-radius: 12px;
			border: 1px solid var(--color-border);
		}
		
		.education-info p {
			margin: 0.5em 0;
			color: var(--color-text);
		}
		
		.education-info strong {
			color: var(--color-text);
		}
		
		.education-desc {
			color: var(--color-text-light);
			font-size: 0.875rem;
			margin-top: 1em;
		}
		
		.contact p {
			margin-bottom: 1.5em;
			color: var(--color-text);
		}
		
		.contact-links {
			display: flex;
			flex-wrap: wrap;
			gap: 1em;
		}
		
		.contact-link {
			display: flex;
			align-items: center;
			gap: 0.5em;
			padding: 0.75em 1.25em;
			background-color: var(--color-bg-secondary);
			color: var(--color-text);
			text-decoration: none;
			border-radius: 8px;
			border: 1px solid var(--color-border);
			transition: all 0.2s;
		}
		
		.contact-link:hover {
			border-color: var(--color-primary);
			color: var(--color-primary);
			transform: translateY(-2px);
		}
		
		.contact-link svg {
			width: 20px;
			height: 20px;
		}
		
		@media (max-width: 768px) {
			.about-page {
				padding: 2em 1em;
			}
			
			.about-header {
				padding: 1.5em;
				margin-bottom: 2em;
			}
			
			.about-header h1 {
				font-size: 1.75rem;
			}
			
			.skill-categories {
				grid-template-columns: 1fr;
			}
			
			.contact-info {
				flex-direction: column;
			}
			
			.contact-item {
				justify-content: center;
			}
			
			.experience-list {
				gap: 1.5em;
			}
		}
	</style>
</BlogLayout>
