---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BlogLayout title={`博客 - ${SITE_TITLE}`} description="所有技术文章列表">
	<div class="blog-page">
		<header class="page-header">
			<h1>所有文章</h1>
			<p class="description">
				已发布 <span class="count">{posts.length}</span> 篇文章
			</p>
		</header>
		
		<div class="posts-list">
			{posts.map((post) => (
				<PostCard post={post} />
			))}
		</div>
		
		{posts.length === 0 && (
			<div class="empty-state">
				<p>还没有文章，敬请期待！</p>
			</div>
		)}
	</div>
</BlogLayout>

<style>
	.blog-page {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	
	.page-header {
		text-align: center;
		margin-bottom: 3em;
		padding: 2em;
		background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
		border-radius: 16px;
		border: 1px solid var(--color-border);
	}
	
	.page-header h1 {
		font-size: 2.5rem;
		margin: 0 0 0.5em 0;
		color: var(--color-text);
	}
	
	.page-header .description {
		font-size: 1.125rem;
		color: var(--color-text-light);
		margin: 0;
	}
	
	.page-header .count {
		color: var(--color-primary);
		font-weight: 600;
	}
	
	.posts-list {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2em;
	}
	
	.empty-state {
		text-align: center;
		padding: 4em 2em;
		color: var(--color-text-light);
		font-size: 1.25rem;
	}
	
	@media (max-width: 768px) {
		.blog-page {
			padding: 1em;
		}
		
		.page-header {
			padding: 1.5em;
			margin-bottom: 2em;
		}
		
		.page-header h1 {
			font-size: 1.75rem;
		}
		
		.posts-list {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
	}
</style>
