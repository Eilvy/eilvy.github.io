---
import BlogLayout from '../layouts/BlogLayout.astro';
import PostCard from '../components/PostCard.astro';
import Tag from '../components/Tag.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, POSTS_PER_PAGE } from '../consts';

const posts = await getCollection('blog');

// 过滤草稿并排序
const publishedPosts = posts
	.filter((post) => !(post.data as any).draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, POSTS_PER_PAGE);

// 获取所有标签
const allTags = new Set<string>();
publishedPosts.forEach((post) => {
	if ((post.data as any).tags) {
		(post.data as any).tags.forEach((tag: string) => allTags.add(tag));
	}
});
---

<BlogLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<div class="home">
		<section class="hero">
			<h1>👋 你好！这里是Eilvy的博客！</h1>
			<p class="lead">
				分享后端开发、 VibeCoding、运维开发等主题的文章
			</p>
		</section>
		
		<section class="latest-posts">
			<div class="section-header">
				<h2>最新文章</h2>
				<a href="/blog" class="view-all">
					查看全部
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M5 12h14M12 5l7 7-7 7"/>
					</svg>
				</a>
			</div>
			
			<div class="posts-grid">
				{posts.map((post) => (
					<PostCard post={post} />
				))}
			</div>
		</section>
		
		{allTags.size > 0 && (
			<section class="tags-section">
				<h2>热门标签</h2>
				<div class="tags-cloud">
					{Array.from(allTags).slice(0, 10).map((tag) => (
						<Tag name={tag} href={`/tags/${tag.toLowerCase()}/`} />
					))}
				</div>
			</section>
		)}
	</div>
</BlogLayout>

<style>
	.home {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	
	.hero {
		text-align: center;
		margin-bottom: 4em;
		padding: 3em 2em;
		background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
		border-radius: 16px;
		border: 1px solid var(--color-border);
	}
	
	.hero h1 {
		font-size: 3rem;
		margin-bottom: 0.5em;
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		line-height: 1.2;
	}
	
	.hero .lead {
		font-size: 1.25rem;
		color: var(--color-text-light);
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.6;
	}
	
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2em;
		padding-bottom: 1em;
		border-bottom: 2px solid var(--color-border);
	}
	
	.section-header h2 {
		font-size: 1.75rem;
		margin: 0;
		color: var(--color-text);
	}
	
	.view-all {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--color-primary);
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95rem;
		transition: all 0.2s;
	}
	
	.view-all:hover {
		color: var(--color-primary-dark);
	}
	
	.view-all svg {
		width: 18px;
		height: 18px;
		transition: transform 0.2s;
	}
	
	.view-all:hover svg {
		transform: translateX(4px);
	}
	
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2em;
		margin-bottom: 4em;
	}
	
	.tags-section {
		margin-top: 4em;
	}
	
	.tags-section h2 {
		font-size: 1.75rem;
		margin-bottom: 1.5em;
		color: var(--color-text);
	}
	
	.tags-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75em;
	}
	
	@media (max-width: 768px) {
		.home {
			padding: 1em;
		}
		
		.hero {
			padding: 2em 1em;
			margin-bottom: 3em;
		}
		
		.hero h1 {
			font-size: 2rem;
		}
		
		.hero .lead {
			font-size: 1rem;
		}
		
		.posts-grid {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
		
		.section-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 1em;
		}
	}
</style>
