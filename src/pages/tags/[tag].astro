---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = new Set<string>();
	
	posts.forEach((post) => {
		if (post.data.tags) {
			post.data.tags.forEach((tag) => tags.add(tag));
		}
	});
	
	return Array.from(tags).map((tag) => ({
		params: { tag: tag.toLowerCase() },
		props: { tagName: tag },
	}));
}

interface Props {
	tagName: string;
}

const { tagName } = Astro.props;
const posts = (await getCollection('blog'))
	.filter((post) => 
		!post.data.draft && 
		post.data.tags &&
		post.data.tags.some((tag) => tag.toLowerCase() === Astro.params.tag)
	)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BlogLayout title={`标签：${tagName} - ${SITE_TITLE}`} description={`包含标签 "${tagName}" 的文章`}>
	<div class="tag-page">
		<header class="page-header">
			<h1>
				<span class="tag-label">#</span>
				{tagName}
			</h1>
			<p class="description">
				找到 <span class="count">{posts.length}</span> 篇相关文章
			</p>
		</header>
		
		<div class="posts-list">
			{posts.map((post) => (
				<PostCard post={post} />
			))}
		</div>
		
		{posts.length === 0 && (
			<div class="empty-state">
				<p>该标签下还没有文章</p>
				<a href="/blog" class="back-link">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M19 12H5M12 19l-7-7 7-7"/>
					</svg>
					返回博客列表
				</a>
			</div>
		)}
		
		<div class="back-to-blog">
			<a href="/blog" class="back-link">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M19 12H5M12 19l-7-7 7-7"/>
				</svg>
				返回博客列表
			</a>
		</div>
	</div>
</BlogLayout>

<style>
	.tag-page {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	
	.page-header {
		text-align: center;
		margin-bottom: 3em;
		padding: 2em;
		background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
		border-radius: 16px;
		border: 1px solid var(--color-border);
	}
	
	.page-header h1 {
		font-size: 2.5rem;
		margin: 0 0 0.5em 0;
		color: var(--color-text);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.25em;
	}
	
	.tag-label {
		color: var(--color-primary);
	}
	
	.page-header .description {
		font-size: 1.125rem;
		color: var(--color-text-light);
		margin: 0;
	}
	
	.page-header .count {
		color: var(--color-primary);
		font-weight: 600;
	}
	
	.posts-list {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2em;
		margin-bottom: 3em;
	}
	
	.empty-state {
		text-align: center;
		padding: 4em 2em;
		color: var(--color-text-light);
		font-size: 1.25rem;
	}
	
	.back-to-blog {
		text-align: center;
		margin-top: 2em;
	}
	
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--color-primary);
		text-decoration: none;
		font-weight: 500;
		font-size: 1rem;
		transition: all 0.2s;
	}
	
	.back-link:hover {
		color: var(--color-primary-dark);
	}
	
	.back-link svg {
		width: 20px;
		height: 20px;
		transition: transform 0.2s;
	}
	
	.back-link:hover svg {
		transform: translateX(-4px);
	}
	
	@media (max-width: 768px) {
		.tag-page {
			padding: 1em;
		}
		
		.page-header {
			padding: 1.5em;
			margin-bottom: 2em;
		}
		
		.page-header h1 {
			font-size: 1.75rem;
		}
		
		.posts-list {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
	}
</style>
